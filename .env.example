# Copy this file to .env and fill in your keys.
# cp .env.example .env   (Linux/macOS)
# copy .env.example .env  (Windows)

# OpenAI-compatible APIs
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1

# Alibaba Cloud Bailian (DashScope)
BAILIAN_API_KEY=
BAILIAN_BASE_URL_OPENAI=https://coding.dashscope.aliyuncs.com/v1
BAILIAN_BASE_URL_ANTHROPIC=https://coding.dashscope.aliyuncs.com/apps/anthropic

DASHSCOPE_API_KEY=
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# DeepSeek (used by default LLM in my_llm.py)
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com

# Optional third-party endpoints
XIAOAI_API_KEY=
XIAOAI_BASE_URL=

# Search / tools (Tavily is required for tavily_search in tools.py)
TAVILY_API_KEY=
SERPAPI_API_KEY=
ZHIPU_API_KEY=

# Anthropic / Zhipu (optional, if you use those providers)
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=https://api.anthropic.com
ZHIPUAI_API_KEY=
ZHIPUAI_BASE_URL=https://open.bigmodel.cn/api/paas/v4/

# LangSmith (optional tracing)
LANGCHAIN_TRACING_V2=false
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=myclaw

# Optional: other tokens used elsewhere
GITHUB_TOKEN=
HUGGINGFACEHUB_API_TOKEN=
